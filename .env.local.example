NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-remote-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-remote-legacy-service-role-jwt-for-dev-login-only
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe payment secrets live in Supabase Edge Function secrets only.
# Required there: STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, and
# APP_BASE_URL or CHECKOUT_ALLOWED_APP_URLS.

# Optional for public forms and generated content.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
GEMINI_API_KEY=
COHERE_API_KEY=
