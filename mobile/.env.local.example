EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-remote-anon-or-publishable-key

# Optional local App Store Connect submit credentials.
# Keep the .p8 file local. It is ignored by git.
EXPO_ASC_APP_ID=1234567890
EXPO_ASC_API_KEY_PATH=./AuthKey_XXXXXXXXXX.p8
EXPO_ASC_API_KEY_ID=XXXXXXXXXX
EXPO_ASC_API_KEY_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Optional local Expo auth for EAS checks and submit preflight.
# Prefer CI/project secrets for shared automation.
EXPO_TOKEN=replace-with-local-expo-token
